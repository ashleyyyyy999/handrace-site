{
  "version": 2,
  "builds": [
    { "src": "api/proxy.js", "use": "@vercel/node" },
    { "src": "public/**",    "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/Quadrant.woff2",    "dest": "/public/Quadrant.woff2" },
    { "src": "/quadrant.css",       "dest": "/public/quadrant.css"   },
    { "src": "/_next/(.*)",         "dest": "https://midday.ai/_next/$1" },
    { "src": "/cdn-cgi/(.*)",       "dest": "https://midday.ai/cdn-cgi/$1" },
    { "src": "/images/(.*)",        "dest": "https://midday.ai/images/$1" },
    { "src": "/(.*)",               "dest": "/api/proxy?p=$1" }
  ]
}
