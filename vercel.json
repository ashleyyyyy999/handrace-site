{
  "version": 2,
  "rewrites": [
    { "source": "/Quadrant.woff2", "destination": "/public/Quadrant.woff2" },
    { "source": "/quadrant.css",   "destination": "/public/quadrant.css"   },
    { "source": "/_next/:path*",   "destination": "https://midday.ai/_next/:path*" },
    { "source": "/cdn-cgi/:path*", "destination": "https://midday.ai/cdn-cgi/:path*" },
    { "source": "/images/:path*",  "destination": "https://midday.ai/images/:path*" },
    { "source": "/:path*",         "destination": "/api/proxy?p=:path*" }
  ]
}
